TELEGRAM_BOT_TOKEN=
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
MY_TELEGRAM_USER_ID=
SERPER_API_KEY=
TAVILY_API_KEY=
MY_NAME=
MY_COMPANY_NAME=
MY_ROLE=
MY_ONE_LINER=

# ── Autonomy ─────────────────────────────────────────────
# If true, the agent executes risky actions (send email, post to X, delete
# calendar events) WITHOUT asking. Default false = approval-gated.
AUTO_APPROVE=false
# How often (hours) the proactive heartbeat runs between 09:00-21:00.
HEARTBEAT_HOURS=4
# Autonomy level: cautious (gate writes too) | balanced (default) | autonomous (no gate).
AUTONOMY_LEVEL=balanced
# Daily safety cap on LLM calls (0 = unlimited). Protects against runaway loops.
DAILY_LLM_CALL_CAP=0
# Kill switch: if true, the agent will not act (no model calls, no autonomy).
AGENT_PAUSED=false

# ── Local model (Ollama, optional) ───────────────────────
# Free, private, offline fallback. Install Ollama + pull a model first.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── Semantic cache ─────────────────────────────────────
# Cache near-duplicate LLM prompts to save tokens (default on).
SEMANTIC_CACHE=true
CACHE_DISTANCE_THRESHOLD=0.08

# ── Google Calendar (optional) ───────────────────────────
# Put your OAuth client secret JSON at GOOGLE_CREDENTIALS_PATH, then run:
#   python scripts/google_auth.py
GOOGLE_CREDENTIALS_PATH=./data/google_credentials.json
GOOGLE_TOKEN_PATH=./data/google_token.json

# ── X / Twitter (optional, paid API for meaningful access) ─
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
